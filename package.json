{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "cd server && npx tsx src/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "build:server": "cd server && npx tsc",
    "preview": "vite preview",
    "db:migrate": "cd server && npx prisma migrate dev",
    "db:push": "cd server && npx prisma db push",
    "db:seed": "cd server && npx tsx src/prisma/seed.ts",
    "db:studio": "cd server && npx prisma studio",
    "db:generate": "cd server && npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/three": "^0.184.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "2.1.1",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "prisma": "^7.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router-dom": "^7.17.0",
